{
  "name": "dialect-app",
  "version": "1.0.0",
  "description": "方言词汇搜索应用",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.yourname.dialect-app",
    "productName": "方言档案",
    "files": [
      "build/**/*",
      "node_modules/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "electronDownload": {
      "cache": "D:/111study/2025春/guochuang/pack/electron-v20.3.12-win32-x64"
    },
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "pack-env",
        "to": "python"
      },
      {
        "from": "pack-env",
        "to": "python",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "audio",
        "to": "backend/audio",
        "filter": [
          "**/*.mp3"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.education"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Education"
    }
  },
  "devDependencies": {
    "electron": "^20.3.12",
    "electron-builder": "^23.6.0",
    "electron-is-dev": "^2.0.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "fs-extra": "^11.3.0",
    "electron-is-dev": "^2.0.0"
  }
}
